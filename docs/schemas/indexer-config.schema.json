{
  "$ref": "#/definitions/IndexerConfig",
  "definitions": {
    "IndexerConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0",
          "description": "Schema version (current: \"1.0\")"
        },
        "codebases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Unique identifier for codebase (e.g., \"my-repo\")"
              },
              "root": {
                "type": "string",
                "description": "Absolute path to repo root"
              },
              "gitUrl": {
                "type": "string",
                "format": "uri",
                "description": "Optional git clone URL if root path missing"
              },
              "trackedBranches": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "description": "Array of branch names to index (e.g., [\"main\", \"develop\"])"
              }
            },
            "required": ["id", "root", "trackedBranches"],
            "additionalProperties": false,
            "description": "Per-codebase configuration (tracked branches, repository metadata)"
          },
          "minItems": 1,
          "description": "Array of codebase configurations (required)"
        },
        "graph": {
          "type": "object",
          "properties": {
            "neo4jUri": {
              "type": "string",
              "description": "Neo4j connection URI (env var substitution supported)"
            },
            "neo4jUser": {
              "type": "string",
              "description": "Neo4j username (env var substitution supported)"
            },
            "neo4jPassword": {
              "type": "string",
              "description": "Neo4j password (env var substitution supported)"
            }
          },
          "required": ["neo4jUri", "neo4jUser", "neo4jPassword"],
          "additionalProperties": false,
          "description": "Neo4j graph database configuration (required)"
        },
        "vectors": {
          "type": "object",
          "properties": {
            "qdrantUrl": {
              "type": "string",
              "description": "Qdrant instance URL (env var substitution supported)"
            },
            "collectionName": {
              "type": "string",
              "description": "Qdrant collection name for embeddings. Default: \"texere-embeddings\""
            }
          },
          "required": ["qdrantUrl"],
          "additionalProperties": false,
          "description": "Qdrant vector store configuration (required)"
        },
        "cloneBasePath": {
          "type": "string",
          "description": "Base directory for git clones if codebase root missing"
        },
        "reposDirectory": {
          "type": "string",
          "description": "Base directory to auto-discover per-repo configs (v1 stub)"
        },
        "repoPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Glob patterns for per-repo config discovery (v1 stub)"
        },
        "security": {
          "type": "object",
          "properties": {
            "denyPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Glob patterns to exclude from indexing and LLM processing. Default: [\".env\", \"*.key\"]"
            },
            "allowPatterns": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ],
              "description": "If set, only files matching these patterns are indexed. Default: null (allow all)"
            }
          },
          "additionalProperties": false,
          "description": "Security & privacy configuration"
        },
        "embedding": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "enum": ["openai", "local"],
              "description": "Embedding provider (\"openai\", \"local\", etc.). Default: \"openai\""
            },
            "modelName": {
              "type": "string",
              "description": "Model identifier for provider. Default: \"text-embedding-3-small\""
            },
            "dimensions": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Embedding vector dimensionality. Default: 1536"
            },
            "batchSize": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Batch size for embedding requests. Default: 128"
            }
          },
          "additionalProperties": false,
          "description": "Embedding provider configuration"
        },
        "llm": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["openai", "anthropic"],
              "description": "LLM provider (\"openai\", \"anthropic\", etc.). Default: \"openai\""
            },
            "model": {
              "type": "string",
              "description": "Model identifier for LLM. Default: \"gpt-4o-mini\""
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Generation temperature (0.0–1.0). Default: 0.3"
            },
            "maxTokens": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Max output tokens for LLM responses. Default: 1024"
            }
          },
          "additionalProperties": false,
          "description": "LLM provider configuration"
        },
        "worker": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["local", "bullmq"],
              "description": "Executor type (\"local\" or \"bullmq\"). Default: \"local\""
            },
            "concurrency": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Max concurrent index operations. Default: 4"
            },
            "retryAttempts": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of retries on failure. Default: 3"
            },
            "retryDelayMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Delay between retries (milliseconds). Default: 5000"
            }
          },
          "additionalProperties": false,
          "description": "Worker/executor configuration"
        }
      },
      "required": ["version", "codebases", "graph", "vectors"],
      "additionalProperties": false,
      "description": "Texere Indexer configuration. See configuration_spec.md §1–5 for complete reference."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
