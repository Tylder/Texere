###############################################
# Texere / Python — .gitignore (clean layout) #
###############################################

## Python caches & bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

## Virtual environments
.venv/
venv/
ENV/
env/
__pypackages__/
pip-wheel-metadata/

## Build artifacts
build/
dist/
site/
*.egg-info/
.eggs/

## Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

## Type checking
.mypy_cache/
.pytype/
.pyre/
.dmypy.json
.pyrightcache/

## Linters & tooling caches
.ruff_cache/
.cache/

## Tox / Nox / Hypothesis / Benchmarks
.tox/
.nox/
.hypothesis/
.benchmarks/

## Hatch / UV / Lock files
.uv/
# If you choose to commit locks, remove this line:
requirements.lock

## Jupyter
.ipynb_checkpoints

## Editors / IDE
.vscode/
.idea/
*.swp
*.swo

## OS files
.DS_Store
Thumbs.db

## Env / Config
.env
.env.*
!.env.example
*.local
.envrc
.direnv/

## Logs & project artifacts
logs/
*.log
.texere/

## Docker / Runtime
docker-compose.override.yml
tmp/
*.pid

## Node (optional)
node_modules/
npm-debug.log*
yarn-error.log*

## Data
data/
*.sqlite3
