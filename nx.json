{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "ignore": ["**/vendor/**"],
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "check-types"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json"
        }
      }
    },
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "test",
        "ciTargetName": "test-ci"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/package.json",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/tsconfig.lib.json"
      ],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "cache": true,
      "options": {
        "clean": false
      }
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["{projectRoot}/src/**", "{workspaceRoot}/eslint.config.mjs"],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/package.json",
        "{projectRoot}/tsconfig*.json"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/vitest.setup.ts",
        "{projectRoot}/package.json"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "cache": true
    },
    "test-ci": {
      "dependsOn": ["^test-ci"],
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/vitest.setup.ts",
        "{projectRoot}/package.json"
      ],
      "outputs": ["{projectRoot}/coverage/**"],
      "cache": true
    },
    "test:coverage": {
      "executor": "nx:run-script",
      "options": { "script": "test:coverage" }
    }
  }
}
