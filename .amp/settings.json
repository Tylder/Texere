{
  "amp.mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "type": "stdio"
    },
    "sourcegraph": {
      "command": "node",
      "args": ["/home/anon/sourcegraph-mcp/dist/index.js"],
      "env": {
        "SRC_ENDPOINT": "http://localhost:7080",
        "SRC_ACCESS_TOKEN": "[REDACTED:sourcegraph-access-token-v3]"
      }
    },
    "playwright": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--init",
        "--security-opt",
        "no-new-privileges",
        "--cpus",
        "1",
        "--memory",
        "2g",
        "-v",
        "/tmp:/tmp",
        "mcp/playwright"
      ],
      "type": "stdio"
    },
    "code-search": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--gpus",
        "all",
        "--cpus",
        "1",
        "--memory",
        "2Gb",
        "-v",
        "claude-code-search-data:/root/.claude_code_search",
        "-v",
        "/home/anon/:/home/anon:ro",
        "-e",
        "HF_TOKEN=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",
        "claude-context-local-py-ccl:latest"
      ]
    },
    "jetbrains-debugger": {
      "type": "sse",
      "url": "http://localhost:63342/debugger-mcp/sse"
    }
  },
  "amp.guardedFiles.allowlist": [
