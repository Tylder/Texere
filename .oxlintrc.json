{
  "env": {
    "node": true,
    "browser": false,
    "es2025": true
  },
  "rules": {
    "correctness": "error",
    "suspicious": "warn",
    "restriction": "warn",
    "style": "off",
    "nursery": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    ".turbo/",
    "coverage/",
    "out/",
    ".test/",
    ".cache/",
    "**/vendor/",
    "**/*.d.ts"
  ]
}
