{
  "name": "texere",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "format": "prettier . --write --cache",
    "format:check": "prettier . --check --cache",
    "lint": "bash -lc 'set +e; oxlint; OX=$?; eslint .; ES=$?; if [ $OX -ne 0 ] || [ $ES -ne 0 ]; then exit 1; fi'",
    "lint:fix": "eslint . --fix && oxlint --fix",
    "quality": "bash -lc 'set +e; pnpm format:check; F=$?; pnpm lint; L=$?; pnpm typecheck; T=$?; pnpm test:unit; U=$?; if [ $F -ne 0 ] || [ $L -ne 0 ] || [ $T -ne 0 ] || [ $U -ne 0 ]; then exit 1; fi'",
    "test:integration": "turbo run test:integration",
    "test:unit": "turbo run test:unit",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@texere/eslint-config": "workspace:*",
    "@texere/typescript-config": "workspace:*",
    "@types/node": "25.2.3",
    "eslint": "9.39.2",
    "eslint-plugin-oxlint": "1.46.0",
    "oxlint": "1.47.0",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.0",
    "turbo": "2.8.8",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
