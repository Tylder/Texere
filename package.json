{
  "name": "monorepo_template",
  "private": true,
  "scripts": {
    "build": "nx run-many --target=build --all --parallel",
    "dev": "nx run-many --target=dev --all --parallel",
    "dev:log": "bash scripts/dev-log.sh",
    "e2e": "nx run-many --target=e2e --all --parallel",
    "format": "prettier . --write --cache",
    "format:check": "prettier . --check --cache",
    "format:staged": "node ./scripts/format-staged.mjs",
    "lint": "nx run-many --target=lint --all --parallel",
    "post:report": "pnpm run format && nx run-many --targets=lint,check-types,test:coverage,build --all --parallel && node scripts/aggregate-coverage.mjs",
    "prepare": "husky",
    "quality": "nx run-many --targets=format:check,lint,check-types,test,build --all --parallel",
    "studio:dev": "npx @langchain/langgraph-cli dev",
    "test": "nx run-many --target=test --all --parallel",
    "test:coverage": "nx run-many --target=test:coverage --all --parallel && node scripts/aggregate-coverage.mjs",
    "typecheck": "nx run-many --target=check-types --all --parallel",
    "typecheck:watch:log": "bash scripts/typecheck-watch-log.sh"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.2",
    "@nx/devkit": "22.1.3",
    "@nx/eslint": "^22.1.3",
    "@nx/eslint-plugin": "^22.1.3",
    "@nx/js": "22.1.3",
    "@nx/next": "^22.1.3",
    "@nx/playwright": "22.1.3",
    "@nx/vite": "^22.1.3",
    "@nx/vitest": "22.1.3",
    "@playwright/test": "^1.57.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.3",
    "@swc/helpers": "~0.5.17",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.0",
    "@types/jsdom": "27.0.0",
    "@types/node": "24.10.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "4.0.15",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-playwright": "^2.4.0",
    "husky": "9.1.7",
    "jsdom": "27.2.0",
    "lint-staged": "16.2.7",
    "nx": "22.1.3",
    "prettier": "3.7.4",
    "prettier-plugin-packagejson": "2.5.20",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sharp": "^0.34.5",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "ai": "^5.0.108"
    }
  }
}
