{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "node"
    ],
    "composite": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
