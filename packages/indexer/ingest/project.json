{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "indexer-ingest",
  "projectType": "library",
  "sourceRoot": "packages/indexer/ingest/src",
  "tags": ["domain:indexer", "layer:ingest", "runtime:server"],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "outputs": ["{workspaceRoot}/dist/packages/indexer/ingest"],
      "inputs": ["default", "{projectRoot}/tsconfig.lib.json", "{projectRoot}/src/**"],
      "dependsOn": ["^build"]
    },
    "check-types": {
      "executor": "nx:run-script",
      "options": {
        "script": "check-types"
      },
      "inputs": [
        "default",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/tsconfig.lib.json",
        "{projectRoot}/src/**",
        "{projectRoot}/tests/**"
      ]
    },
    "lint": {
      "executor": "nx:run-script",
      "options": {
        "script": "lint"
      },
      "inputs": ["default", "{projectRoot}/src/**", "{projectRoot}/eslint.config.*"]
    },
    "test": {
      "executor": "nx:run-script",
      "options": {
        "script": "test"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:coverage": {
      "executor": "nx:run-script",
      "options": {
        "script": "test:coverage"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:watch": {
      "executor": "nx:run-script",
      "options": {
        "script": "test:watch"
      }
    }
  }
}
