{
  "name": "@repo/indexer-ingest-ts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript/JavaScript language indexer: SCIP + AST fallback symbol extraction for Texere Knowledge Graph",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "@repo/source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "@repo/source": "./src/*.ts",
      "import": "./dist/*.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "check-types": "tsc -b tsconfig.json",
    "check-types:clean": "tsc -b tsconfig.json --stopOnBuildErrors && tsc -b tsconfig.json --clean",
    "lint": "eslint . --cache --cache-location \"$NX_WORKSPACE_ROOT/.cache/eslint/\"",
    "scip:generate": "PROTO_DIR=packages/indexer/ingest-ts/src/scip PROTO_FILE=scip.proto OUT_DIR=packages/indexer/ingest-ts/src/scip/generated PLUGIN=packages/indexer/ingest-ts/node_modules/.bin/protoc-gen-ts_proto protoc --proto_path=$PROTO_DIR --plugin=$PLUGIN --ts_proto_out=$OUT_DIR --ts_proto_opt=outputIndex=true,esModuleInterop=true,useOptionals=all $PROTO_FILE && node packages/indexer/ingest-ts/scripts/add-ts-nocheck.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@repo/indexer-core": "workspace:*",
    "@repo/indexer-types": "workspace:*",
    "@sourcegraph/scip-typescript": "^0.4.0",
    "google-protobuf": "^4.0.1",
    "protobufjs": "^8.0.0",
    "typescript": "^5.9"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "simple-git": "^3.30.0",
    "ts-proto": "^2.8.3",
    "vitest": "^4.0.15"
  }
}
