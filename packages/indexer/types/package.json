{
  "name": "@repo/indexer-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types for the Texere indexer (FileIndexResult, LanguageIndexer, graph/query bundles).",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json --incremental",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
