{
  "name": "@repo/tools-mastra",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/tools-mastra/src",
  "projectType": "library",
  "tags": ["npm:public", "scope:tools", "type:adapter"],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "outputs": ["{workspaceRoot}/dist/packages/tools-mastra"]
    },
    "check-types": {
      "executor": "nx:run-script",
      "options": {
        "script": "check-types"
      }
    },
    "lint": {
      "executor": "nx:run-script",
      "options": {
        "script": "lint"
      }
    },
    "test": {
      "executor": "nx:run-script",
      "options": {
        "script": "test"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:coverage": {
      "executor": "nx:run-script",
      "options": {
        "script": "test:coverage"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:watch": {
      "executor": "nx:run-script",
      "options": {
        "script": "test:watch"
      }
    }
  }
}
