{
  "name": "@repo/tools-mastra",
  "version": "1.0.0",
  "description": "Mastra adapter for CoreTool definitions",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --incremental",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@repo/tools-core": "workspace:*",
    "zod": "^3.25.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.0.15",
    "eslint": "9.39.1",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  },
  "peerDependencies": {
    "@mastra/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": false
    }
  }
}
