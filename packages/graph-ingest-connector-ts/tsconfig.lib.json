{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "noEmitOnError": true,
    "tsBuildInfoFile": ".cache/tsconfig.lib.tsbuildinfo",
    "paths": {
      "@c4312/scip": ["./src/scip-types.d.ts"]
    }
  },
  "references": [
    {
      "path": "../graph-core/tsconfig.lib.json"
    },
    {
      "path": "../graph-ingest/tsconfig.lib.json"
    },
    {
      "path": "../graph-store/tsconfig.lib.json"
    }
  ],
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**"]
}
