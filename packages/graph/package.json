{
  "name": "@texere/graph",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "@texere/source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "check-types": "pnpm typecheck",
    "lint": "eslint .",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:dev": "vitest --config vitest.unit.config.ts",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@texere/eslint-config": "workspace:*",
    "@texere/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.2.3",
    "eslint": "9.39.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
