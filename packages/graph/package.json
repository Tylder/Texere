{
  "name": "@texere/graph",
  "version": "0.1.2",
  "description": "Immutable SQLite-backed knowledge graph library with keyword, semantic, and hybrid retrieval.",
  "keywords": [
    "agent-memory",
    "graph-database",
    "knowledge-graph",
    "retrieval",
    "sqlite",
    "texere",
    "vector-search"
  ],
  "homepage": "https://github.com/Tylder/Texere",
  "bugs": {
    "url": "https://github.com/Tylder/Texere/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tylder/Texere.git",
    "directory": "packages/graph"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "@texere/source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/db.ts",
    "src/edges.ts",
    "src/embedder.ts",
    "src/index.ts",
    "src/nodes.ts",
    "src/pagination.ts",
    "src/replace-node.ts",
    "src/sanitize.ts",
    "src/schema.ts",
    "src/search.ts",
    "src/traverse.ts",
    "src/types.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "check-types": "pnpm typecheck",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:mutation": "stryker run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:dev": "vitest --config vitest.unit.config.ts",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "better-sqlite3": "^12.6.2",
    "nanoid": "^5.1.6",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@texere/eslint-config": "workspace:*",
    "@texere/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.2.3",
    "eslint": "9.39.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
