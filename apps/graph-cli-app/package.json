{
  "name": "@repo/graph-cli-app",
  "version": "0.0.0",
  "private": true,
  "description": "Interactive CLI for testing graph system features",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "@repo/source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "check-types": "tsc -b tsconfig.json",
    "check-types:clean": "tsc -b tsconfig.json --stopOnBuildErrors && tsc -b tsconfig.json --clean",
    "dev": "node --watch dist/index.js",
    "lint": "eslint . --cache --cache-location \"$NX_WORKSPACE_ROOT/.cache/eslint/\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@repo/graph-core": "workspace:*",
    "@repo/graph-ingest": "workspace:*",
    "@repo/graph-ingest-connector-scip-ts": "workspace:*",
    "@repo/graph-projection": "workspace:*",
    "@repo/graph-store": "workspace:*",
    "commander": "^14.0.2",
    "enquirer": "^2.4.1",
    "ink": "^6.6.0",
    "pastel": "^4.0.0",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
