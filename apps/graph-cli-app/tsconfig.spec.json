{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".cache/ts-spec",
    "types": ["vitest/globals", "node"],
    "composite": true,
    "tsBuildInfoFile": ".cache/tsconfig.spec.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vitest.config.ts", "vitest.setup.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
