{
  "name": "mastra",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mastra",
  "projectType": "application",
  "tags": ["runtime:server"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mastra dev",
        "cwd": "apps/mastra"
      },
      "cache": false
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Mastra build skipped - add agents/tools/workflows first'",
        "cwd": "apps/mastra"
      },
      "outputs": ["{projectRoot}/.mastra/output"],
      "cache": false
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node .mastra/output/index.mjs",
        "cwd": "apps/mastra"
      },
      "cache": false
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/mastra/**/*.{js,ts,jsx,tsx}"]
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier apps/mastra --check --cache"
      }
    },
    "check-types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter mastra check-types"
      }
    },
    "vitest:test": {
      "executor": "@nx/vitest:vitest",
      "options": {
        "passWithNoTests": true
      },
      "cache": false
    },
    "test-ci": {
      "executor": "@nx/vitest:vitest",
      "options": {
        "passWithNoTests": true,
        "run": true,
        "coverage": true
      },
      "cache": false
    }
  }
}
