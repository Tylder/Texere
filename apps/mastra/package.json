{
  "name": "mastra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "mastra build",
    "check-types": "tsc --noEmit",
    "dev": "mastra dev",
    "lint": "eslint --max-warnings 0",
    "start": "node .mastra/output/index.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
