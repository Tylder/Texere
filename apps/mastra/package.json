  "dependencies": {
    "@mastra/core": "^0.24.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.0.15",
    "eslint": "9.39.1",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  }
}
