# LLM Provider API Keys (choose at least one)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Ollama Configuration (local development)
# Use host.docker.internal when running in Docker; localhost otherwise
# NOTE: baseURL must include /api endpoint path for ollama-ai-provider-v2
OLLAMA_BASE_URL=http://host.docker.internal:11434/api
OLLAMA_MODEL=llama3.2:3b-instruct-q5_K_S

# Mastra Server Configuration
MASTRA_PORT=4111
MASTRA_HOST=0.0.0.0

# Database Configuration (SQLite for development)
DATABASE_URL=file:./dev.db

# Application Environment
NODE_ENV=development
