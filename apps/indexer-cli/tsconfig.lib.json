{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "noEmitOnError": true,
    "tsBuildInfoFile": ".cache/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**"],
  "references": [
    {
      "path": "../../packages/indexer/utils/tsconfig.lib.json"
    },
    {
      "path": "../../packages/indexer/types/tsconfig.lib.json"
    },
    {
      "path": "../../packages/indexer/ingest/tsconfig.lib.json"
    },
    {
      "path": "../../packages/indexer/core/tsconfig.lib.json"
    }
  ]
}
