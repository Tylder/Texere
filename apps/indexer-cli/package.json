{
  "name": "@repo/indexer-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Texere Indexer – CLI for snapshot indexing and configuration management",
  "type": "module",
  "bin": {
    "indexer": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json --incremental",
    "check-types": "tsc --build tsconfig.json --noEmit",
    "dev": "node --watch dist/main.js",
    "dev:branches": "pnpm build && node dist/main.js --repo texere --tracked-branches --dry-run",
    "dev:help": "pnpm build && node dist/main.js --help",
    "dev:snapshot": "pnpm build && node dist/main.js --repo texere --dry-run",
    "dev:verbose": "pnpm build && node dist/main.js --repo texere --verbose",
    "lint": "eslint . --cache --cache-location \"$NX_WORKSPACE_ROOT/.cache/eslint/\"",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@repo/indexer-core": "workspace:*",
    "@repo/indexer-ingest": "workspace:*",
    "@repo/indexer-types": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
