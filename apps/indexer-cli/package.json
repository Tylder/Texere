{
  "name": "@repo/indexer-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Texere Indexer – CLI for snapshot indexing and configuration management",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "indexer": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "check-types": "tsc -b tsconfig.json && tsc -b tsconfig.json --clean",
    "dev:help": "pnpm build && node dist/main.js --help",
    "dev:list": "pnpm build && node dist/main.js list",
    "dev:list:verbose": "pnpm build && node dist/main.js list --verbose",
    "dev:run:daemon": "pnpm build && node dist/main.js run --daemon --verbose",
    "dev:run:detached": "pnpm build && node dist/main.js run --detached",
    "dev:run:once": "pnpm build && node dist/main.js run --once --dry-run",
    "dev:run:once:force": "pnpm build && node dist/main.js run --once --force",
    "dev:status": "pnpm build && node dist/main.js status",
    "dev:stop": "pnpm build && node dist/main.js stop",
    "dev:validate": "pnpm build && node dist/main.js validate",
    "lint": "eslint . --cache --cache-location \"$NX_WORKSPACE_ROOT/.cache/eslint/\"",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@repo/indexer-core": "workspace:*",
    "@repo/indexer-ingest": "workspace:*",
    "@repo/indexer-types": "workspace:*",
    "@repo/indexer-utils": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
