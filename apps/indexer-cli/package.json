{
  "name": "@repo/indexer-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Texere Indexer – CLI for snapshot indexing and configuration management",
  "type": "module",
  "bin": {
    "indexer": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json --incremental",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "dev": "node --watch dist/main.js",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@repo/indexer-core": "workspace:*",
    "@repo/indexer-ingest": "workspace:*",
    "@repo/indexer-types": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
