{
  "name": "@repo/langgraph-dev",
  "projectType": "application",
  "sourceRoot": "src",
  "tags": ["scope:app", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @repo/langgraph-dev build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @repo/langgraph-dev lint"
      }
    },
    "check-types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @repo/langgraph-dev check-types"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @repo/langgraph-dev test:coverage"
      }
    }
  }
}
