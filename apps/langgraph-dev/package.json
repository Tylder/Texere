    "@repo/typescript-config": "workspace:*",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "eslint": "9.39.1",
    "tsx": "^4.0.0",
    "typescript": "5.9.3"
  }
}
