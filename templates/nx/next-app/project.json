{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "__name__",
  "projectType": "application",
  "sourceRoot": "apps/__name__/app",
  "tags": ["runtime:web", "scope:__scope__"],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": { "script": "build" },
      "outputs": ["{projectRoot}/.next"],
      "inputs": [
        "default",
        "{projectRoot}/tsconfig.app.json",
        "{projectRoot}/app/**",
        "{projectRoot}/pages/**",
        "{projectRoot}/components/**"
      ],
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "nx:run-script",
      "options": { "script": "dev" },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-script",
      "options": { "script": "lint" },
      "inputs": [
        "default",
        "{projectRoot}/app/**",
        "{projectRoot}/pages/**",
        "{projectRoot}/components/**",
        "{projectRoot}/eslint.config.*"
      ]
    },
    "check-types": {
      "executor": "nx:run-script",
      "options": { "script": "check-types" },
      "inputs": [
        "default",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/tsconfig.app.json",
        "{projectRoot}/app/**",
        "{projectRoot}/components/**"
      ]
    },
    "test": {
      "executor": "nx:run-script",
      "options": { "script": "test" },
      "outputs": ["{projectRoot}/coverage"],
      "inputs": [
        "default",
        "{projectRoot}/app/**",
        "{projectRoot}/components/**",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/vitest.setup.ts",
        "{projectRoot}/package.json"
      ],
      "dependsOn": ["^test"],
      "cache": true
    },
    "test:coverage": {
      "executor": "nx:run-script",
      "options": { "script": "test:coverage" },
      "outputs": ["{projectRoot}/coverage/**"],
      "inputs": [
        "default",
        "{projectRoot}/app/**",
        "{projectRoot}/components/**",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/vitest.setup.ts",
        "{projectRoot}/package.json"
      ],
      "dependsOn": ["^test:coverage"],
      "cache": true
    }
  }
}
