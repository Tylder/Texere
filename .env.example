# LangGraph Studio (local dev only - no tracing)
# Use any dummy value for local development; data stays local with LANGSMITH_TRACING=false
LANGSMITH_API_KEY=dev-local-key
LANGSMITH_TRACING=false

# Ollama LLM Configuration
# Default points to local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q5_K_S

# Langfuse Observability (optional)
# Leave empty to skip Langfuse integration
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3030

# Indexer Configuration (optional for run-once/daemon modes)
# Path to system-wide indexer config file (default: .indexer-config.json in working dir)
INDEXER_CONFIG_PATH=

# Neo4j Graph Database (required for indexer)
# Connection URI, username, password for graph persistence
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant Vector Store (required for indexer)
# URL to Qdrant instance for embeddings
QDRANT_URL=http://localhost:6333

# OpenAI API (optional, for embeddings and LLM-assisted extraction)
# Leave empty to skip or use local stubs
OPENAI_API_KEY=
