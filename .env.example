# Development environment variables
PYTHONPATH=src
CHECKPOINT_DIR=./.texere/checkpoints
LOG_LEVEL=DEBUG

# Langfuse Observability Configuration
# Get API keys from: http://localhost:3000 (after running docker-compose.langfuse.yml)
# Or sign up for cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
