# LangGraph Studio (local dev only - no tracing)
# Use any dummy value for local development; data stays local with LANGSMITH_TRACING=false
LANGSMITH_API_KEY=dev-local-key
LANGSMITH_TRACING=false

# Ollama LLM Configuration
# Default points to local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q5_K_S

# Langfuse Observability (optional)
# Leave empty to skip Langfuse integration
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3030
