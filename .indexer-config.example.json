{
  "version": "1.0",
  "codebases": [
    {
      "id": "texere-indexer-test-repo",
      "root": "/home/anon/TexereIndexerRestRepo",
      "trackedBranches": ["main"]
    }
  ],
  "graph": {
    "neo4jUri": "${NEO4J_URI}",
    "neo4jUser": "${NEO4J_USER}",
    "neo4jPassword": "${NEO4J_PASSWORD}"
  },
  "vectors": {
    "qdrantUrl": "${QDRANT_URL}",
    "collectionName": "texere-embeddings"
  },
  "security": {
    "denyPatterns": [".env", "*.key", "*.pem", "secrets/**"],
    "allowPatterns": null
  },
  "embedding": {
    "model": "openai",
    "modelName": "text-embedding-3-small",
    "dimensions": 1536,
    "batchSize": 128
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.3,
    "maxTokens": 1024
  },
  "worker": {
    "type": "local",
    "concurrency": 4,
    "retryAttempts": 3,
    "retryDelayMs": 5000
  }
}
